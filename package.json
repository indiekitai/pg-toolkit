{
  "name": "@indiekitai/pg-toolkit",
  "version": "0.1.0",
  "description": "Unified CLI for all IndieKit PostgreSQL tools — inspect, diff, top, health, types",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pg-toolkit": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@indiekitai/pg-inspect": "^0.1.0",
    "@indiekitai/pg-diff": "^0.1.0",
    "@indiekitai/pg-top": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["postgresql", "cli", "toolkit", "inspect", "diff", "monitor", "mcp"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/indiekitai/pg-toolkit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
